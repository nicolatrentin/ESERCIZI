import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

# 1. Carica il dataset
url = 'https://gist.githubusercontent.com/seankross/a412dfbd88b3db70b74b/raw/5f23f993cd87c283ce766e7ac6b329ee7cc2e1d1/mtcars.csv'
df = pd.read_csv(url)

# 2. Prepara i dati
# Scikit-learn richiede che le feature (X) siano una matrice 2D. Usiamo le doppie quadre [[ ]] per DataFrame.
X = df[['disp']]
y = df['mpg']

# 3. Inizializza e addestra (fitta) il modello di regressione lineare
modello = LinearRegression()
modello.fit(X, y)

# 4. Crea le previsioni (la retta di regressione)
y_pred = modello.predict(X)

# Stampiamo i parametri del modello
print(f"Coefficiente angolare (Pendenza): {modello.coef_[0]:.4f}")
print(f"Intercetta: {modello.intercept_:.4f}")
print(f"Coefficiente di determinazione (R^2): {modello.score(X, y):.4f}")

# 5. Plot dei dati e della retta di regressione
plt.figure(figsize=(10, 6))
plt.scatter(X, y, color='blue', alpha=0.7, label='Dati reali (mtcars)')
plt.plot(X, y_pred, color='red', linewidth=2, label='Retta di regressione')

plt.title('Regressione Lineare: Consumo (mpg) vs Cilindrata (disp)')
plt.xlabel('Cilindrata / Displacement (pollici cubici)')
plt.ylabel('Consumo / Miles Per Gallon (mpg)')
plt.legend()
plt.grid(True, alpha=0.3)
plt.show()