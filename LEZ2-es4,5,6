dati_co2 = np.array([12.5, 19.1, 15.0, 22.4, 18.5, 17.9]) # Array di esempio

# Valori sopra le 18 tonnellate
sopra_18 = dati_co2[dati_co2 > 18]
print("\nValori sopra soglia (>18):", len(sopra_18))
print("Media dei valori sopra soglia:", np.mean(sopra_18))

# Frazione sul totale
frazione = np.sum(sopra_18) / np.sum(dati_co2)
print("Frazione totale:", frazione)