import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np

def simulazione_lanci(N):
    # Genero N lanci casuali (0 o 1) e calcolo la % di teste (valore 1)
    lanci = np.random.randint(0, 2, size=N) 
    return (np.sum(lanci) / N) * 100

# Genero i campioni e calcolo i risultati
campioni = [n for n in range(10, 20001, int(20000/100))]
risultati = [simulazione_lanci(n) for n in campioni]

# Creo un DataFrame per facilitare il grafico
df = pd.DataFrame({'Lanci': campioni, 'Teste_%': risultati})

# Creo il grafico
plt.figure(figsize=(10,6))
sns.lineplot(data=df, x='Lanci', y='Teste_%', color="blue")
plt.axhline(50, color='red', linestyle='--') # Linea teorica del 50%
plt.xlabel("Numero di lanci")
plt.ylabel("Percentuale teste (%)")
plt.title("Legge dei grandi numeri")
plt.show()