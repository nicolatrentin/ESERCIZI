import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

url = "https://raw.githubusercontent.com/datasciencedojo/datasets/master/titanic.csv"
df = pd.read_csv(url)

# 1. Righe e colonne
print("Dimensioni:", df.shape)

# 2. Valori mancanti per colonna
print("\nMancanti:\n", df.isnull().sum())

# 3. Riempio i vuoti in 'Embarked' con la moda (il più frequente)
df['Embarked'] = df['Embarked'].fillna(df['Embarked'].mode()[0])

# 4. Righe duplicate
print("\nDuplicate:", df.duplicated().sum())

# 5. Età media per classe e riempimento valori vuoti in 'Age'
print("\nEtà media per classe:\n", df.groupby('Pclass')['Age'].mean())
df['Age'] = df['Age'].fillna(df['Age'].mean()) # Uso la media globale per i vuoti

# 6. Boxplot dell'età per classe
plt.figure(figsize=(8, 5))
sns.boxplot(data=df, x='Pclass', y='Age', palette='Set2')
plt.title("Età per Classe")
plt.show()

# 7. Boxplot diviso tra uomini e donne
plt.figure(figsize=(10, 6))
sns.boxplot(data=df, x='Pclass', y='Age', hue='Sex', palette='pastel')
plt.title("Età per Classe e Sesso")
plt.show()